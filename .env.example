# Feedback form endpoint (optional but recommended).
# Create a free form at https://formspree.io (or Tally) and paste its POST URL.
# Example (Formspree): https://formspree.io/f/abcdwxyz
NEXT_PUBLIC_FEEDBACK_ENDPOINT=

# Optional fallback: if no endpoint is set, the feedback button opens the user's
# mail client addressed to this email instead.
NEXT_PUBLIC_FEEDBACK_EMAIL=
